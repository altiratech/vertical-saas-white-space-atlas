{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence.schema.json",
  "title": "Evidence",
  "type": "object",
  "required": ["label", "detail", "source_ids"],
  "additionalProperties": false,
  "properties": {
    "label": {
      "type": "string",
      "minLength": 1
    },
    "detail": {
      "type": "string",
      "minLength": 1
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
